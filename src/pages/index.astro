---
import PageHeader from '@brainage04/astro-shell/components/PageHeader.astro';
import TerminalPanel from '@brainage04/astro-shell/components/TerminalPanel.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { baseHref, recipeHref, recipes } from '../data/recipes';

const shoppingHref = `${baseHref()}ShoppingList/`;
---
<SiteLayout title="Home" description="Recipe calculators for cookies and brownies with Woolworths cost estimates and bake notes.">
  <div class="site-stack">
    <PageHeader title="BakingCookingRecipes" description="Recipe calculators for cookies and brownies with Woolworths cost estimates and bake notes." />
    <TerminalPanel title="Recipes">
      <div class="grid">
        {recipes.map((recipe) => (
          <a class="recipe-card note-card" href={recipeHref(recipe.slug)}>
            <h2>{recipe.cardTitle}</h2>
          </a>
        ))}
      </div>
    </TerminalPanel>
    <TerminalPanel title="Shopping">
      <p>Choose how many batches of cookies and brownies you want to make, then combine them into one grocery list.</p>
      <p><a href={shoppingHref}>Open combined shopping list</a></p>
    </TerminalPanel>
  </div>
</SiteLayout>
