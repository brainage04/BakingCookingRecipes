---
import TerminalPanel from '../components/TerminalPanel.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import {
  experimentTodos,
  ingredients,
  recipeMeta,
  sourceIngredients,
  sourceInstructions,
} from '../data/recipe';

const calculatorData = {
  recipeMeta,
  ingredients,
};

const estimatedDoughGrams = ingredients.reduce((total, ingredient) => {
  if (ingredient.key === 'eggs') return total + ingredient.nutritionQuantity;
  if (ingredient.metricUnit === 'ml') return total + ingredient.metricQuantity;
  if (ingredient.metricUnit === 'g') return total + ingredient.metricQuantity;
  return total;
}, 0);
---

<SiteLayout title="Cookie Calculator">
  <div class="site-stack">

    <TerminalPanel title="Calculator" class="stack" id="calculator">
      <div class="calculator-grid" aria-live="polite">
        <div class="control-card batch-card">
          <label class="field" for="batch-input">
            <span>Batches</span>
            <input id="batch-input" type="number" min="0" step="any" inputmode="decimal" value="1" aria-describedby="batch-help" />
          </label>
          <small id="batch-help" class="muted">Enter any unsigned decimal batch count.</small>
        </div>

        <div class="control-card toggle-list" aria-label="Ingredient alternatives">
          <label>
            <input id="toggle-stevia" type="checkbox" checked />
            <span>Replace white sugar with Whole Earth Stevia Sugar Replacement 600g.</span>
          </label>
          <label>
            <input id="toggle-brown-monkfruit" type="checkbox" checked />
            <span>Replace brown sugar with Lakanto Monkfruit Sweetener Brown 450g.</span>
          </label>
          <label>
            <input id="toggle-protein-flour" type="checkbox" checked />
            <span>Replace plain flour with Vetta Smart Protein Plain Flour 1kg.</span>
          </label>
        </div>
        <div class="stat-card stat-cookies">
          <span>Cookies</span>
          <output id="cookies-output">—</output>
          <small>{recipeMeta.cookiesPerBatch} cookies per batch.</small>
        </div>
        <div class="stat-card stat-dough">
          <span>Estimated dough</span>
          <output id="dough-output">{estimatedDoughGrams.toFixed(0)}g</output>
          <small>Dough estimate only; cookie count is fixed at {recipeMeta.cookiesPerBatch} per batch.</small>
        </div>
        <div class="stat-card stat-calories-batch">
          <span>Calories / batch</span>
          <output id="calories-batch-output">—</output>
          <small>Vanilla excluded: Woolworths nutrition is unavailable.</small>
        </div>
        <div class="stat-card stat-calories-serving">
          <span>Calories / cookie</span>
          <output id="calories-serving-output">—</output>
          <small>Calories per batch ÷ {recipeMeta.cookiesPerBatch} cookies.</small>
        </div>
        <div class="stat-card stat-macros-batch">
          <span>Macros / batch</span>
          <output id="macros-batch-output">—</output>
          <small>Protein / carbs / fat. Vanilla excluded.</small>
        </div>
        <div class="stat-card stat-macros-serving">
          <span>Macros / cookie</span>
          <output id="macros-serving-output">—</output>
          <small>Per cookie, using {recipeMeta.cookiesPerBatch} cookies per batch.</small>
        </div>
        <div class="stat-card stat-used-cost">
          <span>Used ingredient cost</span>
          <output id="used-cost-output">—</output>
          <small>Proportional cost for the selected batch count.</small>
        </div>
        <div class="stat-card stat-basket">
          <span>Basket estimate</span>
          <output id="basket-cost-output">—</output>
          <small>Rounds up to whole Woolworths packs.</small>
        </div>
      </div>

      <div class="table-wrap" role="region" aria-label="Scaled ingredient costs" tabindex="0">
        <table>
          <thead>
            <tr>
              <th>Ingredient</th>
              <th>Source amount</th>
              <th>Scaled amount</th>
              <th>Woolworths item</th>
              <th>Used cost</th>
              <th>Packs / basket cost</th>
            </tr>
          </thead>
          <tbody id="ingredient-rows"></tbody>
        </table>
      </div>

    </TerminalPanel>

    <TerminalPanel title="Ingredients" id="recipe">
      <ul>
        {sourceIngredients.map((ingredient) => <li>{ingredient}</li>)}
      </ul>
    </TerminalPanel>

    <TerminalPanel title="Instructions">
      <ol>
        {sourceInstructions.map((step) => <li>{step}</li>)}
      </ol>
    </TerminalPanel>



    <TerminalPanel title="Todo list" id="todo">
      <div class="todo-list" role="list">
        {experimentTodos.map((todo, index) => (
          <label role="listitem">
            <input type="checkbox" data-todo-index={index} />
            <span>{todo}</span>
          </label>
        ))}
      </div>
    </TerminalPanel>
  </div>

  <script is:inline type="application/json" id="calculator-data" set:html={JSON.stringify(calculatorData)} />

  <script is:inline>
    const dataEl = document.getElementById('calculator-data');
    const data = JSON.parse(dataEl?.textContent || '{}');
    const state = {
      batches: 1,
      stevia: true,
      brownMonkfruit: true,
      proteinFlour: true,
    };

    const elements = {
      batchInput: document.getElementById('batch-input'),
      cookiesOutput: document.getElementById('cookies-output'),
      doughOutput: document.getElementById('dough-output'),
      caloriesBatchOutput: document.getElementById('calories-batch-output'),
      caloriesServingOutput: document.getElementById('calories-serving-output'),
      macrosBatchOutput: document.getElementById('macros-batch-output'),
      macrosServingOutput: document.getElementById('macros-serving-output'),
      usedCostOutput: document.getElementById('used-cost-output'),
      basketCostOutput: document.getElementById('basket-cost-output'),
      ingredientRows: document.getElementById('ingredient-rows'),
      steviaToggle: document.getElementById('toggle-stevia'),
      brownMonkfruitToggle: document.getElementById('toggle-brown-monkfruit'),
      proteinFlourToggle: document.getElementById('toggle-protein-flour'),
    };

    const currency = new Intl.NumberFormat('en-AU', { style: 'currency', currency: 'AUD' });
    const number = new Intl.NumberFormat('en-AU', { maximumFractionDigits: 1 });

    function productFor(ingredient) {
      if (ingredient.products.stevia && state.stevia) return ingredient.products.stevia;
      if (ingredient.products.brownMonkfruit && state.brownMonkfruit) return ingredient.products.brownMonkfruit;
      if (ingredient.products.proteinFlour && state.proteinFlour) return ingredient.products.proteinFlour;
      return ingredient.products.default;
    }

    function formatQuantity(value, unit) {
      const formatted = Number.isInteger(value) ? String(value) : number.format(value);
      return `${formatted}${unit === 'egg' ? ` ${value === 1 ? 'egg' : 'eggs'}` : unit}`;
    }

    function formatMoney(value) {
      return currency.format(value);
    }

    function usedCost(ingredient, product, batches = state.batches) {
      return (ingredient.costQuantity * batches * product.priceAud) / product.packageQuantity;
    }

    function basketFor(ingredient, product, batches = state.batches) {
      const packageCount = Math.ceil((ingredient.costQuantity * batches) / product.packageQuantity);
      return {
        packageCount,
        cost: packageCount * product.priceAud,
      };
    }

    function caloriesForBatch(ingredient, product) {
      if (product.kcalPer100g === null) return 0;
      return (ingredient.nutritionQuantity * product.kcalPer100g) / 100;
    }

    function macrosForBatch(ingredient, product) {
      if (product.macrosPer100g === null) return { protein: 0, carbohydrates: 0, fat: 0 };
      const multiplier = ingredient.nutritionQuantity / 100;
      return {
        protein: product.macrosPer100g.protein * multiplier,
        carbohydrates: product.macrosPer100g.carbohydrates * multiplier,
        fat: product.macrosPer100g.fat * multiplier,
      };
    }

    function addMacros(left, right) {
      return {
        protein: left.protein + right.protein,
        carbohydrates: left.carbohydrates + right.carbohydrates,
        fat: left.fat + right.fat,
      };
    }

    function scaleMacros(macros, multiplier) {
      return {
        protein: macros.protein * multiplier,
        carbohydrates: macros.carbohydrates * multiplier,
        fat: macros.fat * multiplier,
      };
    }

    function formatMacros(macros) {
      return `Protein ${number.format(macros.protein)}g\nCarbs ${number.format(macros.carbohydrates)}g\nFat ${number.format(macros.fat)}g`;
    }

    const tableLabels = ['Ingredient', 'Source amount', 'Scaled amount', 'Woolworths item', 'Used cost', 'Packs / basket cost'];

    function renderCell(row, text, className) {
      const cell = document.createElement('td');
      cell.dataset.label = tableLabels[row.children.length] || '';
      if (className) cell.className = className;
      cell.textContent = text;
      row.append(cell);
      return cell;
    }

    function renderLinkCell(row, product) {
      const cell = document.createElement('td');
      cell.dataset.label = tableLabels[row.children.length] || '';
      const link = document.createElement('a');
      link.href = product.url;
      link.textContent = product.name;
      link.target = '_blank';
      link.rel = 'noreferrer';
      const meta = document.createElement('div');
      meta.className = 'muted';
      meta.textContent = `${product.unitPriceLabel} · product ${product.id}`;
      cell.append(link, meta);
      if (product.nutritionNote) {
        const note = document.createElement('small');
        note.className = 'muted';
        note.textContent = product.nutritionNote;
        cell.append(document.createElement('br'), note);
      }
      row.append(cell);
    }

    function render() {
      const batches = state.batches;
      let caloriesPerBatch = 0;
      let macrosPerBatch = { protein: 0, carbohydrates: 0, fat: 0 };
      let usedTotal = 0;
      let basketTotal = 0;
      let doughGramsPerBatch = 0;
      elements.ingredientRows.textContent = '';

      for (const ingredient of data.ingredients) {
        const product = productFor(ingredient);
        const row = document.createElement('tr');
        const scaledMetric = ingredient.metricQuantity * batches;
        const scaledCost = usedCost(ingredient, product, batches);
        const basket = basketFor(ingredient, product, batches);
        const batchCalories = caloriesForBatch(ingredient, product);
        const batchMacros = macrosForBatch(ingredient, product);

        usedTotal += scaledCost;
        basketTotal += basket.cost;
        caloriesPerBatch += batchCalories;
        macrosPerBatch = addMacros(macrosPerBatch, batchMacros);

        if (ingredient.key === 'eggs') {
          doughGramsPerBatch += ingredient.nutritionQuantity;
        } else if (ingredient.metricUnit === 'g' || ingredient.metricUnit === 'ml') {
          doughGramsPerBatch += ingredient.metricQuantity;
        }

        renderCell(row, ingredient.label);
        renderCell(row, ingredient.sourceAmount);
        renderCell(row, formatQuantity(scaledMetric, ingredient.metricUnit));
        renderLinkCell(row, product);
        renderCell(row, formatMoney(scaledCost));
        renderCell(row, `${basket.packageCount} x ${product.name} · ${formatMoney(basket.cost)}`);
        elements.ingredientRows.append(row);
      }

      const doughTotal = doughGramsPerBatch * batches;
      const cookiesPerBatch = data.recipeMeta.cookiesPerBatch;
      const cookies = cookiesPerBatch * batches;
      const caloriesPerCookie = caloriesPerBatch / cookiesPerBatch;
      const macrosPerCookie = scaleMacros(macrosPerBatch, 1 / cookiesPerBatch);

      elements.cookiesOutput.textContent = number.format(cookies);
      elements.doughOutput.textContent = `${number.format(doughTotal)}g`;
      elements.caloriesBatchOutput.textContent = `${number.format(caloriesPerBatch)} kcal`;
      elements.caloriesServingOutput.textContent = `${number.format(caloriesPerCookie)} kcal`;
      elements.macrosBatchOutput.textContent = formatMacros(macrosPerBatch);
      elements.macrosServingOutput.textContent = formatMacros(macrosPerCookie);
      elements.usedCostOutput.textContent = formatMoney(usedTotal);
      elements.basketCostOutput.textContent = formatMoney(basketTotal);
    }

    elements.batchInput?.addEventListener('input', (event) => {
      const value = Number.parseFloat(event.currentTarget.value);
      state.batches = Number.isFinite(value) && value >= 0 ? value : 0;
      render();
    });

    elements.steviaToggle?.addEventListener('change', (event) => {
      state.stevia = event.currentTarget.checked;
      render();
    });

    elements.brownMonkfruitToggle?.addEventListener('change', (event) => {
      state.brownMonkfruit = event.currentTarget.checked;
      render();
    });

    elements.proteinFlourToggle?.addEventListener('change', (event) => {
      state.proteinFlour = event.currentTarget.checked;
      render();
    });

    const todoStorageKey = 'cookie-calculator-todos';
    const storedTodos = JSON.parse(localStorage.getItem(todoStorageKey) || '{}');
    for (const checkbox of document.querySelectorAll('[data-todo-index]')) {
      const index = checkbox.getAttribute('data-todo-index');
      checkbox.checked = Boolean(storedTodos[index]);
      checkbox.addEventListener('change', () => {
        storedTodos[index] = checkbox.checked;
        localStorage.setItem(todoStorageKey, JSON.stringify(storedTodos));
      });
    }

    render();
  </script>
</SiteLayout>
